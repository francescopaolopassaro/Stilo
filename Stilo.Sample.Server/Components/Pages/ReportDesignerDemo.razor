@page "/report-designer"
@rendermode InteractiveServer
@using System.Data
@using Stilo.Documents.Converters
@using Stilo.Documents.HtmlRenderer.Layout
@using Stilo.Reports.Components
@using Stilo.Reports.Data
@using Stilo.Reports.Models
@using Stilo.Reports.Rdl
@inject IWebHostEnvironment Env

<PageTitle>Stilo Reports — Designer</PageTitle>

<div style="height:calc(100vh - 160px);min-height:600px">
    <StiloReportDesigner ReportName="FatturaDemo" Report="_demoReport" PreviewDataSources="_previewDataSources" HtmlToPdfConverter="_pdfConverter" />
</div>

@code {
    private readonly IHtmlToPdfConverter _pdfConverter = new HtmlToPdfConverter(PageLayout.A4Portrait(36));
    private readonly List<ReportDataSource> _previewDataSources = new();
    private Report _demoReport = new();

    private static TablixCell TextCell(string expr, Style? style = null) => new()
    {
        Items = { new Textbox { Paragraphs = { new Paragraph { Runs = { new TextRun { Value = expr, Style = style ?? new Style() } } } } } }
    };

    protected override void OnInitialized()
    {
        var table = new DataTable();
        table.Columns.Add("Prodotto", typeof(string));
        table.Columns.Add("Quantita", typeof(int));
        table.Columns.Add("PrezzoUnitario", typeof(decimal));
        table.Columns.Add("Totale", typeof(decimal));

        void Add(string prod, int qty, decimal price)
        {
            table.Rows.Add(prod, qty, price, qty * price);
        }
        Add("Notebook Pro 15\"", 2, 1299.99m);
        Add("Mouse Wireless", 5, 34.50m);
        Add("Tastiera Meccanica", 3, 89.90m);
        Add("Monitor 27\" 4K", 1, 549.00m);
        Add("Webcam HD", 4, 79.99m);
        Add("Hub USB-C", 3, 45.50m);

        _previewDataSources.Add(ReportDataSource.FromDataTable("Fattura", table));

        // Genera un vero file .rdlc su disco (round-trip Write→Read) invece di usare
        // direttamente l'oggetto in memoria: dimostra il caricamento reale di un report salvato.
        var rdlcPath = Path.Combine(Env.ContentRootPath, "SampleReports", "FatturaDemo.rdlc");
        Directory.CreateDirectory(Path.GetDirectoryName(rdlcPath)!);
        var rdlXml = RdlWriter.Write(BuildDemoReport());
        File.WriteAllText(rdlcPath, rdlXml);
        _demoReport = RdlReader.Read(File.ReadAllText(rdlcPath));
    }

    private static Report BuildDemoReport()
    {
        var report = new Report { Description = "Fattura demo" };
        report.Body.Height = RdlSize.FromMm(140);

        // Origine dati e dataset registrati nel modello (visibili nel pannello Dati e persistiti nel .rdlc).
        report.DataSources.Add(new DataSource { Name = "Fattura" });
        var dataSet = new Stilo.Reports.Models.DataSet { Name = "Fattura", Query = new Query { DataSourceName = "Fattura" } };
        dataSet.Fields.Add(new Field { Name = "Prodotto", DataField = "Prodotto" });
        dataSet.Fields.Add(new Field { Name = "Quantita", DataField = "Quantita" });
        dataSet.Fields.Add(new Field { Name = "PrezzoUnitario", DataField = "PrezzoUnitario" });
        dataSet.Fields.Add(new Field { Name = "Totale", DataField = "Totale" });
        report.DataSets.Add(dataSet);

        report.PageHeader = new PageSection { Height = RdlSize.FromMm(15) };
        report.PageHeader.Items.Add(new Textbox
        {
            Name = "HeaderTitle",
            Top = RdlSize.FromMm(2),
            Left = RdlSize.FromMm(10),
            Width = RdlSize.FromMm(100),
            Height = RdlSize.FromMm(10),
            Paragraphs = { new Paragraph { Runs = { new TextRun { Value = "Fattura n. FT-2026-001" } } } },
        });

        report.PageFooter = new PageSection { Height = RdlSize.FromMm(10) };
        report.PageFooter.Items.Add(new Textbox
        {
            Name = "FooterPage",
            Top = RdlSize.FromMm(1),
            Left = RdlSize.FromMm(180),
            Width = RdlSize.FromMm(20),
            Height = RdlSize.FromMm(8),
            Paragraphs = { new Paragraph { Runs = { new TextRun { Value = "=\"Pag. \" & Globals!PageNumber & \" di \" & Globals!TotalPages" } } } },
        });

        report.Body.Items.Add(new Rectangle
        {
            Name = "HeaderBand",
            Top = RdlSize.FromMm(0),
            Left = RdlSize.FromMm(10),
            Width = RdlSize.FromMm(190),
            Height = RdlSize.FromMm(15),
            Style = new Style { BackgroundColor = "#555b63" },
        });
        report.Body.Items.Add(new Textbox
        {
            Name = "ClientLabel",
            Top = RdlSize.FromMm(4),
            Left = RdlSize.FromMm(14),
            Width = RdlSize.FromMm(150),
            Height = RdlSize.FromMm(8),
            Style = new Style { Color = "white", FontWeight = "Bold", FontSize = "14pt" },
            Paragraphs = { new Paragraph { Runs = { new TextRun { Value = "Cliente: Central Discount Store" } } } },
        });

        var tablix = new Tablix
        {
            Name = "FatturaTablix",
            DataSetName = "Fattura",
            Top = RdlSize.FromMm(20),
            Left = RdlSize.FromMm(10),
            Width = RdlSize.FromMm(190),
            Height = RdlSize.FromMm(60),
        };
        tablix.Body.ColumnWidths.Add(RdlSize.FromMm(80));
        tablix.Body.ColumnWidths.Add(RdlSize.FromMm(30));
        tablix.Body.ColumnWidths.Add(RdlSize.FromMm(40));
        tablix.Body.ColumnWidths.Add(RdlSize.FromMm(40));

        var headerStyle = new Style { Color = "white", FontWeight = "Bold", BackgroundColor = "#0787FF" };
        tablix.Body.Rows.Add(new TablixRow
        {
            Height = RdlSize.FromMm(7),
            Cells =
            {
                TextCell("Prodotto", headerStyle),
                TextCell("Quantità", headerStyle),
                TextCell("Prezzo unitario", headerStyle),
                TextCell("Totale", headerStyle),
            },
        });
        tablix.Body.Rows.Add(new TablixRow
        {
            Height = RdlSize.FromMm(6),
            Cells =
            {
                TextCell("=Fields!Prodotto.Value"),
                TextCell("=Fields!Quantita.Value"),
                TextCell("=Format(Fields!PrezzoUnitario.Value, \"C2\")"),
                TextCell("=Format(Fields!Totale.Value, \"C2\")"),
            },
        });
        var totalStyle = new Style { FontWeight = "Bold", BackgroundColor = "#f3f4f6" };
        tablix.Body.Rows.Add(new TablixRow
        {
            Height = RdlSize.FromMm(6),
            Cells =
            {
                TextCell("Totale fattura", totalStyle),
                TextCell("=Sum(Fields!Quantita.Value)", totalStyle),
                TextCell("", totalStyle),
                TextCell("=Format(Sum(Fields!Totale.Value), \"C2\")", totalStyle),
            },
        });
        report.Body.Items.Add(tablix);

        var chart = new Chart
        {
            Name = "QuantitaChart",
            Top = RdlSize.FromMm(85),
            Left = RdlSize.FromMm(10),
            Width = RdlSize.FromMm(190),
            Height = RdlSize.FromMm(50),
            Type = ChartType.Column,
            Title = "Quantità per prodotto",
            CategoryExpression = "=Fields!Prodotto.Value",
            DataSetName = "Fattura",
        };
        chart.Series.Add(new ChartSeries { Name = "Quantità", ValueExpression = "=Fields!Quantita.Value" });
        report.Body.Items.Add(chart);

        return report;
    }
}
